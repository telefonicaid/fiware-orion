# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify HTTP notification duration metrics lifecycle during protocol changes (HTTP -> MQTT/Kafka -> HTTP)

--SHELL-INIT--
dbInit CB

# Start broker with cache sync interval of 4s
brokerStart CB 0 IPv4 -subCacheIval 4 --cache
accumulatorStart

--SHELL--

##
# 01. Create initial HTTP subscription
# 02. Get Query subscription before notification: verify duration metrics are not present
# 03. Create entity (triggers notification)
# 04. Get Query subscription: verify duration metrics are present
# 05. PATCH subscription description
# 06. Get Query subscription: verify duration metrics are preserved
# 07. PATCH subscription protocol to MQTT
# 08. Check DB directly after patch to MQTT: verify duration metrics are removed
# 09. Get Query subscription: verify duration metrics are removed
# 10. PATCH subscription protocol back to HTTP
# 11. Get Query subscription: verify duration metrics remain absent (reset)
# 12. Trigger another notification by updating entity
# 13. Get Query subscription: verify duration metrics re-appear
# 14. PATCH subscription protocol to Kafka
# 15. Get Query subscription: verify duration metrics are removed
# 16. PATCH subscription protocol back to HTTP
# 17. Get Query subscription: verify duration metrics remain absent (reset)
# 18. PATCH subscription description again
# 19. Get Query subscription: verify duration metrics remain absent (reset)
#

echo "01. Create initial HTTP subscription"
echo "===================================="
sub_payload='{
    "subject": {
        "entities": [
            {
                "id": "E",
                "type": "T"
            }
        ]
    },
    "notification": {
        "http": {
            "url": "http://localhost:'${LISTENER_PORT}'/notify"
        }
    }
}'
orionCurl -X POST --url /v2/subscriptions --payload "$sub_payload"
echo

SUB_ID=$(echo "$_responseHeaders" | grep Location | awk -F/ '{ print $4 }' | tr -d "\r\n")

echo "02. Get Query subscription before notification: verify duration metrics are not present"
echo "======================================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "03. Create entity (triggers notification)"
echo "========================================="
payload='{
    "id": "E",
    "type": "T",
    "A": {
        "type": "Number",
        "value": 10
    }
}'
orionCurl -X POST --url /v2/entities --payload "$payload"
echo
echo

echo "04. Get Query subscription: verify duration metrics are present"
echo "================================================================"
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "05. PATCH subscription description"
echo "=================================="
payload='{
  "description": "Modified sub"
}'
orionCurl -X PATCH --url /v2/subscriptions/$SUB_ID --payload "$payload"
echo

echo "06. Get Query subscription: verify duration metrics are preserved"
echo "================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "07. PATCH subscription protocol to MQTT"
echo "======================================="
payload='{
    "notification": {
        "mqtt": {
            "url": "mqtt://localhost:1883",
            "topic": "testTopic"
        }
    }
}'
orionCurl -X PATCH --url /v2/subscriptions/$SUB_ID --payload "$payload"
echo

echo "08. Check DB directly after patch to MQTT: verify duration metrics are removed"
echo "=============================================================================="
mongoCmd ${CB_DB_NAME} 'db.csubs.findOne({_id: ObjectId("'$SUB_ID'")}, {_id:0, expiration:0})' | python ${SCRIPT_HOME}/jsonBeautifier.py
echo

echo "09. Get Query subscription: verify duration metrics are removed"
echo "==============================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "10. PATCH subscription protocol back to HTTP"
echo "============================================"
payload='{
    "notification": {
        "http": {
            "url": "http://localhost:'${LISTENER_PORT}'/notify"
        }
    }
}'
orionCurl -X PATCH --url /v2/subscriptions/$SUB_ID --payload "$payload"
echo

echo "11. Get Query subscription: verify duration metrics remain absent (reset)"
echo "=========================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "12. Trigger another notification by updating entity"
echo "==================================================="
payload='{
    "value": 30
}'
orionCurl -X PUT --url /v2/entities/E/attrs/A/value --payload "$payload"
echo
echo

echo "13. Get Query subscription: verify duration metrics re-appear"
echo "=============================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "14. PATCH subscription protocol to Kafka"
echo "========================================"
payload='{
    "notification": {
        "kafka": {
            "url": "kafka://localhost:9092",
            "topic": "testTopicKafka"
        }
    }
}'
orionCurl -X PATCH --url /v2/subscriptions/$SUB_ID --payload "$payload"
echo

echo "15. Get Query subscription: verify duration metrics are removed"
echo "================================================================"
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "16. PATCH subscription protocol back to HTTP"
echo "============================================"
payload='{
    "notification": {
        "http": {
            "url": "http://localhost:'${LISTENER_PORT}'/notify"
        }
    }
}'
orionCurl -X PATCH --url /v2/subscriptions/$SUB_ID --payload "$payload"
echo

echo "17. Get Query subscription: verify duration metrics remain absent (reset)"
echo "=========================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo

echo "18. PATCH subscription description again"
echo "========================================"
payload='{
    "description": "Modified sub again"
}'
orionCurl -X PATCH --url /v2/subscriptions/$SUB_ID --payload "$payload"
echo

echo "19. Get Query subscription: verify duration metrics remain absent (reset)"
echo "=========================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


--REGEXPECT--
01. Create initial HTTP subscription
====================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0


02. Get Query subscription before notification: verify duration metrics are not present
=======================================================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 295

{
    "id": "REGEX([0-9a-f]{24})",
    "notification": {
        "attrs": [],
        "attrsFormat": "normalized",
        "covered": false,
        "http": {
            "url": "http://localhost:9997/notify"
        },
        "onlyChangedAttrs": false
    },
    "status": "active",
    "subject": {
        "condition": {
            "attrs": [],
            "notifyOnMetadataChange": true
        },
        "entities": [
            {
                "id": "E",
                "type": "T"
            }
        ]
    }
}


