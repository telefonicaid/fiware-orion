        "geometry": "",
        "georel": "",
        "mq": "",
        "q": ""
    },
    "failsCounter": 0,
    "format": "normalized",
    "lastNotification": REGEX(1[6-9]\d+),
    "lastSuccess": 1546337410,
    "lastSuccessCode": 200,
    "metadata": [],
    "onlyChanged": false,
    "reference": "http://localhost:9997/givemeDelay/3",
    "servicePath": "/",
    "status": "active",
    "statusLastChange": 1546337410,
    "throttling": 0,
    "timeout": 0
}


