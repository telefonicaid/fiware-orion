# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
kafka subscription patch cases with key

--SHELL-INIT--
dbInit CB
brokerStart CB

--SHELL--

#
# 01. Create kafka sub without key
# 02. Get sub, see only url and topic in notification
# 03. Update sub element different to notification
# 04. Get sub, see only description changed and key still absent
# 05. Update sub and add key in notification
# 06. Get sub, see url, topic and key in notification
# 07. Update sub and change key value
# 08. Get sub, see updated key value
# 09. Update sub without key and keep previous key value
# 10. Get sub, see updated url and topic and preserved key
# 11. Update sub and set key to empty string
# 12. Get sub, see empty key stored in notification
# 13. Update sub and set key to null
# 14. Get sub, see null key stored in notification
#

echo "01. Create kafka sub without key"
echo "================================"
payload='{
  "description": "Original sub",
  "subject": {
    "entities": [
      {
        "id": "E1",
        "type": "T1"
      }
    ]
  },
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092",
      "topic": "orion"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


SUB_ID=$(echo "$_responseHeaders" | grep Location | awk -F/ '{ print $4 }' | tr -d "\r\n")


echo "02. Get sub, see only url and topic in notification"
echo "==================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "03. Update sub element different to notification"
echo "================================================"
payload='{
  "description": "Modified sub"
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "04. Get sub, see only description changed and key still absent"
echo "=============================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "05. Update sub and add key in notification"
echo "=========================================="
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092",
      "topic": "orion",
      "key": "tenant-id"
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "06. Get sub, see url, topic and key in notification"
echo "==================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "07. Update sub and change key value"
echo "==================================="
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092",
      "topic": "orion",
      "key": "device-id"
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "08. Get sub, see updated key value"
echo "=================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "09. Update sub without key and keep previous key value"
echo "====================================================="
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9093",
      "topic": "cb"
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "10. Get sub, see updated url and topic and preserved key"
echo "========================================================"
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "11. Update sub and set key to empty string"
echo "=========================================="
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9093",
      "topic": "cb",
      "key": ""
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "12. Get sub, see empty key stored in notification"
echo "================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "13. Update sub and set key to null"
echo "=================================="
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9093",
      "topic": "cb",
      "key": null
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "14. Get sub, see null key stored in notification"
echo "================================================"
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


--REGEXPECT--
01. Create kafka sub without key
================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Get sub, see only url and topic in notification
===================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 337

{
    "description": "Original sub",
    "id": "REGEX([0-9a-f]{24})",
    "notification": {
        "attrs": [],
        "attrsFormat": "normalized",
        "covered": false,
        "kafka": {
            "topic": "orion",
            "url": "kafka://localhost:9092"
        },
        "onlyChangedAttrs": false
    },
    "status": "active",
    "subject": {
        "condition": {
            "attrs": [],
            "notifyOnMetadataChange": true
        },
        "entities": [
            {
                "id": "E1",
                "type": "T1"
            }
        ]
    }
}


03. Update sub element different to notification
