# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Add response payload to INFO traces on error

--SHELL-INIT--
dbInit CB
brokerStart CB

--SHELL--

#
# 01. Create entity E1 (type T) with A=1
# 02. Get entity with 200 OK result
# 03. POST /v2/op/update with update action on B so a 422 is raised
# 04. Check log INFO traces (response payload only for the 422 error)
#


echo "01. Create entity E1 (type T) with A=1"
echo "======================================"
payload='{
  "id": "E1",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Number"
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


echo "02. Get entity with 200 OK result"
echo "================================="
orionCurl --url /v2/entities/E1
echo
echo


echo "03. POST /v2/op/update with update action on B so a 422 is raised"
echo "================================================================="
payload='{
  "actionType": "update",
  "entities":
  [
    {
      "type": "T",
      "id":   "E1",
      "B": {
         "type": "Number",
         "value": 2
      }
    }
  ]
}'
orionCurl --url /v2/op/update --payload "$payload"
echo
echo


echo "04. Check log INFO traces (response payload only for the 422 error)"
echo "==================================================================="
cat /tmp/contextBroker.log | grep 'INFO' | awk -F 'msg=' '{print $2}' | grep 'Request received'
echo
echo


--REGEXPECT--
01. Create entity E1 (type T) with A=1
======================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E1?type=T
Content-Length: 0



02. Get entity with 200 OK result
=================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 68

{
    "A": {
        "metadata": {},
        "type": "Number",
        "value": 1
    },
    "id": "E1",
    "type": "T"
}


03. POST /v2/op/update with update action on B so a 422 is raised
=================================================================
HTTP/1.1 422 Unprocessable Content
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 68

{
    "description": "do not exist: E1/T - [ B ]",
    "error": "Unprocessable"
}


04. Check log INFO traces (response payload only for the 422 error)
===================================================================
Request received: POST /v2/entities, request payload (66 bytes): { "id": "E1", "type": "T", "A": { "value": 1, "type": "Number" } }, response code: 201
Request received: GET /v2/entities/E1, response code: 200
Request received: POST /v2/op/update, request payload (110 bytes): { "actionType": "update", "entities": [ { "type": "T", "id": "E1", "B": { "type": "Number", "value": 2 } } ] }, response code: 422, response payload (68 bytes): {"error":"Unprocessable","description":"do not exist: E1/T - [ B ]"}


--TEARDOWN--
brokerStop CB
dbDrop CB
