# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify sequential Fiware-Correlator cbnotif increment when triggering multiple Kafka notifications

--SHELL-INIT--
dbInit CB
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" sub1 sub2
brokerStart CB 164 IPV4
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^sub.*"

--SHELL--

#
# 01. Create KAFKA sub on topic sub1
# 02. Create KAFKA sub on topic sub2
# 03. Create entity E to trigger both subscriptions in a single request
# 04. Dump accumulator and verify cbnotif sequence (1 and 2)
#

echo "01. Create KAFKA sub on topic sub1"
echo "=================================="
payload='{
  "description": "Create KAFKA sub on topic sub1",
  "subject": {
    "entities": [
      {
        "id": "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "sub1"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "02. Create KAFKA sub on topic sub2"
echo "=================================="
payload='{
  "description": "Create KAFKA sub on topic sub2",
  "subject": {
    "entities": [
      {
        "id": "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "sub2"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "03. Create entity E to trigger both subscriptions in a single request"
echo "====================================================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Number"
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


# Not sure but sometimes a notification may be lost at the accumulator if we
# don't wait. Maybe the dump requests is faster than the storing of KAFKA notifications
# due to the lock in accumulator-server.py?
sleep 2s


echo "04. Dump accumulator and verify cbnotif sequence (1 and 2)"
echo "==========================================================="
accumulatorDump
echo
echo


--REGEXPECT--
01. Create KAFKA sub on topic sub1
==================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create KAFKA sub on topic sub2
==================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



03. Create entity E to trigger both subscriptions in a single request
=====================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T
Content-Length: 0



04. Dump accumulator and verify cbnotif sequence (1 and 2)
===========================================================
#SORT_START
Kafka message at topic sub1
Key: (null)
Headers:
  Fiware-Correlator: REGEX([0-9a-f\-]{36}; cbnotif=1)
  Fiware-Servicepath: /
  Ngsiv2-AttrsFormat: normalized
Payload:
{
    "subscriptionId": "REGEX([0-9a-f]{24})",
    "data": [
        {
            "id": "E",
            "type": "T",
            "A": {
                "type": "Number",
                "value": 1,
                "metadata": {}
            }
        }
    ]
}
=======================================
Kafka message at topic sub2
Key: (null)
Headers:
  Fiware-Correlator: REGEX([0-9a-f\-]{36}; cbnotif=2)
  Fiware-Servicepath: /
  Ngsiv2-AttrsFormat: normalized
Payload:
{
    "subscriptionId": "REGEX([0-9a-f]{24})",
    "data": [
        {
            "id": "E",
            "type": "T",
            "A": {
                "type": "Number",
                "value": 1,
                "metadata": {}
            }
        }
    ]
}
=======================================
#SORT_END


--TEARDOWN--
brokerStop CB
dbDrop CB
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" sub1 sub2
