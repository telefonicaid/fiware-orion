# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify that custom headers cannot overwrite Fiware-Correlator or Ngsiv2-AttrsFormat headers

--SHELL-INIT--
dbInit CB
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" sub1
brokerStart CB 164 IPV4
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^sub.*"

--SHELL--

#
# 01. Create a kafkaCustom subscription with custom headers attempting to overwrite Fiware-Correlator and Ngsiv2-AttrsFormat
# 02. Create entity E to trigger the subscription
# 03. Dump accumulator and see Fiware-Correlator and Ngsiv2-AttrsFormat were not modified
#

echo "01. Create a kafkaCustom subscription with custom headers attempting to overwrite Fiware-Correlator and Ngsiv2-AttrsFormat"
echo "=========================================================================================================================="
payload='{
  "description": "KAFKA custom sub attempting header overwrite",
  "subject": {
    "entities": [
      {
        "id": "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "sub1",
      "headers": {
        "Fiware-Correlator": "foo",
        "Ngsiv2-AttrsFormat": "bar",
        "X-Valid-Header": "passed-value"
      }
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "02. Create entity E to trigger the subscription"
echo "==============================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Number"
  }
}'
orionCurl --url /v2/entities --payload "$payload" --correlator MyCorrelator
echo
echo


# Not sure but sometimes a notification may be lost at the accumulator if we
# don't wait. Maybe the dump requests is faster than the storing of KAFKA notifications
# due to the lock in accumulator-server.py?
sleep 2s


echo "03. Dump accumulator and see Fiware-Correlator and Ngsiv2-AttrsFormat were not modified"
echo "======================================================================================="
accumulatorDump
echo
echo


--REGEXPECT--
01. Create a kafkaCustom subscription with custom headers attempting to overwrite Fiware-Correlator and Ngsiv2-AttrsFormat
==========================================================================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create entity E to trigger the subscription
===============================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: MyCorrelator
Location: /v2/entities/E?type=T
Content-Length: 0



03. Dump accumulator and see Fiware-Correlator and Ngsiv2-AttrsFormat were not modified
=======================================================================================
Kafka message at topic sub1
Key: (null)
Headers:
  Fiware-Correlator: MyCorrelator; cbnotif=1
  Fiware-Servicepath: /
  Ngsiv2-AttrsFormat: normalized
  x-valid-header: passed-value
Payload:
{
    "subscriptionId": "REGEX([0-9a-f]{24})",
    "data": [
        {
            "id": "E",
            "type": "T",
            "A": {
                "type": "Number",
                "value": 1,
                "metadata": {}
            }
        }
    ]
}
=======================================


--TEARDOWN--
brokerStop CB
dbDrop CB
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" sub1
