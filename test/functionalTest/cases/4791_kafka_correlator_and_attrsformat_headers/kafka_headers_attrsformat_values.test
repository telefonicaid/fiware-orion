# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify Ngsiv2-AttrsFormat header for values format in Kafka notifications

--SHELL-INIT--
dbInit CB
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" sub1
brokerStart CB 164 IPV4
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^sub.*"

--SHELL--

#
# 01. Create KAFKA sub with attrsFormat: values
# 02. Create entity E to trigger the subscription
# 03. Dump accumulator and verify Ngsiv2-AttrsFormat header
#

echo "01. Create KAFKA sub with attrsFormat: values"
echo "============================================="
payload='{
  "description": "Create KAFKA sub with attrsFormat: values",
  "subject": {
    "entities": [
      {
        "id": "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "attrsFormat": "values",
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "sub1"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "02. Create entity E to trigger the subscription"
echo "==============================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 42,
    "type": "Number"
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


# Not sure but sometimes a notification may be lost at the accumulator if we
# don't wait. Maybe the dump requests is faster than the storing of KAFKA notifications
# due to the lock in accumulator-server.py?
sleep 2s


echo "03. Dump accumulator and verify Ngsiv2-AttrsFormat header"
echo "=========================================================="
accumulatorDump
echo
echo


--REGEXPECT--
01. Create KAFKA sub with attrsFormat: values
=============================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create entity E to trigger the subscription
===============================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T
Content-Length: 0



03. Dump accumulator and verify Ngsiv2-AttrsFormat header
==========================================================
Kafka message at topic sub1
Key: (null)
Headers:
  Fiware-Correlator: REGEX([0-9a-f\-]{36}; cbnotif=1)
  Fiware-Servicepath: /
  Ngsiv2-AttrsFormat: values
Payload:
{
    "subscriptionId": "REGEX([0-9a-f]{24})",
    "data": [
        [
            42
        ]
    ]
}
=======================================


--TEARDOWN--
brokerStop CB
dbDrop CB
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" sub1
