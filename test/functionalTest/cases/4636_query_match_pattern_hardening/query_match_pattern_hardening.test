# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Match pattern fix for POST /v2/op/query

--SHELL-INIT--
dbInit CB
brokerStart CB

--SHELL--

#
# 01. Create entity test1907
# 01. Create entity Test1907
# 03. GET ~=Test to get E_upper
# 04. GET /v2/op/entities ~=Test to get E_upper
#

echo "01. Create entity test1907"
echo "=========================="
payload='{
  "id": "E-lower",
  "type": "T",
  "description": {
    "value": "test1907",
    "type": "Text"
  }
}'
orionCurl --url /v2/entities -X POST --payload "$payload"
echo
echo


echo "02. Create entity Test1907"
echo "=========================="
payload='{
  "id": "E-upper",
  "type": "T",
  "description": {
    "value": "Test1907",
    "type": "Text"
  }
}'
orionCurl --url /v2/entities -X POST --payload "$payload"
echo
echo


echo "03. GET ~=Test to get E_upper"
echo "============================="
orionCurl --url '/v2/entities?q=description~=Test'
echo
echo


echo "04. GET /v2/op/entities ~=Test to get E_upper"
echo "============================================="
payload='{
      "entities": [{
              "idPattern": ".*",
              "type": "T"
          }
      ],
      "expression": {
          "q": "description~=Test"
      }
  }'
orionCurl --url '/v2/op/query' --payload "$payload"
echo
echo




--REGEXPECT--
01. Create entity test1907
==========================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E-lower?type=T
Content-Length: 0



02. Create entity Test1907
==========================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E-upper?type=T
Content-Length: 0



03. GET ~=Test to get E_upper
=============================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 92

[
    {
        "description": {
            "metadata": {},
            "type": "Text",
            "value": "Test1907"
        },
        "id": "E-upper",
        "type": "T"
    }
]


04. GET /v2/op/entities ~=Test to get E_upper
=============================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 92

[
    {
        "description": {
            "metadata": {},
            "type": "Text",
            "value": "Test1907"
        },
        "id": "E-upper",
        "type": "T"
    }
]


--TEARDOWN--
brokerStop CB
dbDrop CB
