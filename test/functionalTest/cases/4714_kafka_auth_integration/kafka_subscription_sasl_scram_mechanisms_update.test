# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
kafka subscription SCRAM mechanisms update and protocol default/override

--SHELL-INIT--
dbInit CB
brokerStart CB

--SHELL--

#
# 01. Create kafka sub OK (SCRAM-SHA-256, default securityProtocol SASL_SSL)
# 02. GET sub checking saslMechanism SCRAM-SHA-256 and securityProtocol SASL_SSL (passwd masked)
# 03. PATCH sub changing saslMechanism to SCRAM-SHA-512 (keep default SASL_SSL)
# 04. GET sub checking saslMechanism SCRAM-SHA-512 and securityProtocol SASL_SSL
# 05. PATCH sub setting securityProtocol SASL_PLAINTEXT (explicit override) and keep SCRAM-SHA-512
# 06. GET sub checking securityProtocol SASL_PLAINTEXT and saslMechanism SCRAM-SHA-512
# 07. PATCH sub removing auth parameters
# 08. GET sub checking auth fields not shown
#

echo "01. Create kafka sub OK (SCRAM-SHA-256, default securityProtocol SASL_SSL)"
echo "========================================================================="
payload='{
  "subject": {
    "entities": [
      {
        "id": "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "user": "user1",
      "passwd": "pass1",
      "saslMechanism": "SCRAM-SHA-256"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
SUB_ID=$(echo "$_responseHeaders" | grep Location | awk -F/ '{ print $4 }' | tr -d "\r\n")
echo
echo


echo "02. GET sub checking saslMechanism SCRAM-SHA-256 and securityProtocol SASL_SSL (passwd masked)"
echo "============================================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "03. PATCH sub changing saslMechanism to SCRAM-SHA-512 (keep default SASL_SSL)"
echo "============================================================================="
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "user": "user1",
      "passwd": "pass2",
      "saslMechanism": "SCRAM-SHA-512"
    }
  }
}'
orionCurl --url /v2/subscriptions/$SUB_ID -X PATCH --payload "$payload"
echo
echo


echo "04. GET sub checking saslMechanism SCRAM-SHA-512 and securityProtocol SASL_SSL"
echo "=============================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "05. PATCH sub setting securityProtocol SASL_PLAINTEXT (explicit override) and keep SCRAM-SHA-512"
echo "================================================================================================"
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "user": "user1",
      "passwd": "pass3",
      "saslMechanism": "SCRAM-SHA-512",
      "securityProtocol": "SASL_PLAINTEXT"
    }
  }
}'
orionCurl --url /v2/subscriptions/$SUB_ID -X PATCH --payload "$payload"
echo
echo


echo "06. GET sub checking securityProtocol SASL_PLAINTEXT and saslMechanism SCRAM-SHA-512"
echo "===================================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "07. PATCH sub removing auth parameters"
echo "======================================"
payload='{
  "notification": {
    "kafka": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion"
    }
  }
}'
orionCurl --url /v2/subscriptions/$SUB_ID -X PATCH --payload "$payload"
echo
echo


echo "08. GET sub checking auth fields not shown"
echo "=========================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


--REGEXPECT--
01. Create kafka sub OK (SCRAM-SHA-256, default securityProtocol SASL_SSL)
=========================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f\\-]{24})
Content-Length: 0



02. GET sub checking saslMechanism SCRAM-SHA-256 and securityProtocol SASL_SSL (passwd masked)
=============================================================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\\-]{36})
Content-Type: application/json
Content-Length: REGEX([0-9]+)

{
    "id": "REGEX([0-9a-f\\-]{24})",
    "notification": {
        "attrs": [],
        "attrsFormat": "normalized",
        "covered": false,
        "kafka": {
            "passwd": "*****",
            "saslMechanism": "SCRAM-SHA-256",
            "securityProtocol": "SASL_SSL",
            "topic": "orion",
            "url": "kafka://localhost:9092,localhost:9094",
            "user": "user1"
        },
        "onlyChangedAttrs": false
    },
    "status": "active",
    "subject": {
        "condition": {
            "attrs": [],
            "notifyOnMetadataChange": true
        },
        "entities": [
            {
                "id": "E",
                "type": "T"
            }
        ]
    }
}


03. PATCH sub changing saslMechanism to SCRAM-SHA-512 (keep default SASL_SSL)
=============================================================================
HTTP/1.1 204 No Content
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\\-]{36})



04. GET sub checking saslMechanism SCRAM-SHA-512 and securityProtocol SASL_SSL
