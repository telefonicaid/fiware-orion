# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
KafkaCustom notification with SASL/PLAIN authentication

--SHELL-INIT--
dbInit CB

# KAFKA_BOOTSTRAP_SASL should point to the new broker: kafkaSasl:9096 (CI) or localhost:9096 (local)

#KAFKA_BOOTSTRAP_TOOLS="localhost:29096"
kafkaCreateTopics "localhost:29096" sub_auth

brokerStart CB 164 IPV4

KAFKA_BOOTSTRAP_SASL="localhost:9096"

accumulatorStart --pretty-print \
  --bootstrapServers "${KAFKA_BOOTSTRAP_SASL}" \
  --kafkaTopic "sub_auth" \
  --kafkaSecurityProtocol "SASL_PLAINTEXT" \
  --kafkaSaslMechanism "PLAIN" \
  --kafkaSaslUser "test" \
  --kafkaSaslPasswd "test-secret"

--SHELL--

#
# Hint: A Kafka cluster accessible at localhost:9096 (SASL_PLAINTEXT + PLAIN) is required for this .test:
#
#
# 01. Create KAFKA custom sub with WRONG user/pass (SASL_PLAINTEXT + PLAIN)
# 02. Upsert to trigger first KAFKA notification, which fails (should NOT notify)
# 03. Dump accumulator (expect EMPTY)
# 04. Get sub and see timesSent:1, failsCounter:1 and lastFailure (but no lastSuccess)
# 05. Upsert to trigger second KAFKA notification, which fails (should NOT notify)
# 06. Dump accumulator (expect EMPTY)
# 07. Get sub and see timesSent:2, failsCounter:2 and lastFailure (but no lastSuccess)
# 08. Dump accumulator (expect 1 message at topic sub_auth)
# 09. PATCH subscription with correct user/pass
# 10. Upsert to trigger third KAFKA notification, which is ok (should notify)
# 11. Get sub and see timesSent:3, lastFailure (old) and lastSuccess but not failsCounter (passwd masked, saslMechanism present)
#

echo "01. Create KAFKA custom sub with WRONG user/pass (SASL_PLAINTEXT + PLAIN)"
echo "========================================================================="
payload='{
  "description": "KAFKA SASL auth sub",
  "subject": {
    "entities": [
      { "id": "E",
      "type": "T"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9096",
      "topic": "sub_auth",
      "user": "test",
      "passwd": "WRONG",
      "saslMechanism": "PLAIN",
      "securityProtocol": "SASL_PLAINTEXT"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo

SUB_ID=$(echo "$_responseHeaders" | grep Location | awk -F/ '{ print $4 }' | tr -d "\r\n")


echo "02. Upsert to trigger first KAFKA notification, which fails (should NOT notify)"
echo "==============================================================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Float"
  }
}'
orionCurl --url '/v2/entities?options=forcedUpdate,upsert' --payload "$payload"
echo
echo


# Not sure but sometimes a notification may be lost at the accumulator if we
# don't wait. Maybe the dump requests is faster than the storing of KAFKA notifications
# due to the lock in accumulator-server.py?
sleep 5s


echo "03. Dump accumulator (expect EMPTY)"
echo "==================================="
accumulatorDump
accumulatorReset
echo
echo


echo "04. Get sub and see timesSent:1, failsCounter:1 and lastFailure (but no lastSuccess)"
echo "===================================================================================="
orionCurl --url /v2/subscriptions
echo
echo


echo "05. Upsert to trigger second KAFKA notification, which fails (should NOT notify)"
echo "================================================================================"
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Float"
  }
}'
orionCurl --url '/v2/entities?options=forcedUpdate,upsert' --payload "$payload"
echo
echo


# Not sure but sometimes a notification may be lost at the accumulator if we
# don't wait. Maybe the dump requests is faster than the storing of KAFKA notifications
# due to the lock in accumulator-server.py?
sleep 5s


echo "06. Dump accumulator (expect EMPTY)"
echo "==================================="
accumulatorDump
accumulatorReset
echo
echo


echo "07. Get sub and see timesSent:2, failsCounter:2 and lastFailure (but no lastSuccess)"
echo "===================================================================================="
orionCurl --url /v2/subscriptions
echo
echo


echo "08. PATCH subscription with correct user/pass"
echo "============================================="
payload='{
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9096",
      "topic": "sub_auth",
      "user": "test",
      "passwd": "test-secret",
      "saslMechanism": "PLAIN",
      "securityProtocol": "SASL_PLAINTEXT"
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "09. Upsert to trigger third KAFKA notification, which is ok (should notify)"
echo "==========================================================================="
payload='{
  "A": {
    "value": 2,
    "type": "Float"
  }
}'
orionCurl --url /v2/entities/E/attrs --payload "$payload"
echo
echo


# Not sure but sometimes a notification may be lost at the accumulator if we
# don't wait. Maybe the dump requests is faster than the storing of KAFKA notifications
# due to the lock in accumulator-server.py?
sleep 2s


echo "10. Dump accumulator (expect 1 message at topic sub_auth)"
echo "========================================================="
accumulatorDump
accumulatorReset
echo
echo


echo "11. Get sub and see timesSent:3, lastFailure (old) and lastSuccess but not failsCounter (passwd masked, saslMechanism present)"
echo "=============================================================================================================================="
orionCurl --url /v2/subscriptions
echo
echo


--REGEXPECT--
01. Create KAFKA custom sub with WRONG user/pass (SASL_PLAINTEXT + PLAIN)
=========================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f\-]{24})
Content-Length: 0



02. Upsert to trigger first KAFKA notification, which fails (should NOT notify)
===============================================================================
HTTP/1.1 204 No Content
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T



03. Dump accumulator (expect EMPTY)
===================================


04. Get sub and see timesSent:1, failsCounter:1 and lastFailure (but no lastSuccess)
====================================================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 562

[
    {
        "description": "KAFKA SASL auth sub",
        "id": "REGEX([0-9a-f\-]{24})",
        "notification": {
            "attrs": [],
            "attrsFormat": "normalized",
            "covered": false,
            "failsCounter": 1,
            "kafkaCustom": {
                "passwd": "*****",
                "saslMechanism": "PLAIN",
                "securityProtocol": "SASL_PLAINTEXT",
                "topic": "sub_auth",
                "url": "kafka://localhost:9096",
                "user": "test"
            },
            "lastFailure": "REGEX(.*)",
            "lastNotification": "REGEX(.*)",
            "onlyChangedAttrs": false,
            "timesSent": 1
        },
        "status": "active",
        "subject": {
            "condition": {
                "attrs": [],
                "notifyOnMetadataChange": true
            },
            "entities": [
                {
                    "id": "E",
                    "type": "T"
                }
            ]
        }
    }
]


