# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify empty key and default payload behavior in kafkaCustom subscriptions

--SHELL-INIT--
dbInit CB
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" orion
brokerStart CB 0 IPV4
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^orion.*"

--SHELL--

#
# 01. Create a custom Kafka subscription with empty key and empty payload
# 02. Create entity E to trigger the subscription
# 03. Get subscriptions and verify that the empty key is stored, while the empty payload is not persisted
# 04. Dump accumulator and verify that the emitted Kafka message has an empty key and the default payload
#

echo "01. Create a custom Kafka subscription with empty key and empty payload"
echo "======================================================================="
payload='{
  "subject": {
    "entities": [
      {
        "id" : "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "key": "",
      "payload": ""
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "02. Create entity E to trigger the subscription"
echo "==============================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Number"
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


# Wait briefly to ensure the Kafka notification is stored by the accumulator
# before requesting the dump.
sleep 1s


echo "03. Get subscriptions and verify that the empty key is stored, while the empty payload is not persisted"
echo "======================================================================================================="
orionCurl --url /v2/subscriptions
echo
echo


echo "04. Dump accumulator and verify that the emitted Kafka message has an empty key and the default payload"
echo "======================================================================================================="
accumulatorDump
echo
echo


--REGEXPECT--
01. Create a custom Kafka subscription with empty key and empty payload
=======================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create entity E to trigger the subscription
===============================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T
Content-Length: 0



03. Get subscriptions and verify that the empty key is stored, while the empty payload is not persisted
=======================================================================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 439

[
    {
        "id": "REGEX([0-9a-f]{24})",
        "notification": {
            "attrs": [],
            "attrsFormat": "normalized",
            "covered": false,
            "kafkaCustom": {
                "key": "",
                "topic": "orion",
                "url": "kafka://localhost:9092,localhost:9094"
            },
            "lastNotification": "REGEX(.*)",
            "lastSuccess": "REGEX(.*)",
            "onlyChangedAttrs": false,
            "timesSent": 1
        },
        "status": "active",
        "subject": {
            "condition": {
                "attrs": [],
                "notifyOnMetadataChange": true
            },
            "entities": [
                {
                    "id": "E",
                    "type": "T"
                }
            ]
        }
    }
]


04. Dump accumulator and verify that the emitted Kafka message has an empty key and the default payload
=======================================================================================================
Kafka message at topic orion
Key:
Headers:
  Fiware-Servicepath: /
Payload:
{
    "subscriptionId": "REGEX([0-9a-f\-]{24})",
    "data": [
        {
            "id": "E",
            "type": "T",
            "A": {
                "type": "Number",
                "value": 1,
                "metadata": {}
            }
        }
    ]
}
=======================================


--TEARDOWN--
brokerStop CB
dbDrop CB
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" orion