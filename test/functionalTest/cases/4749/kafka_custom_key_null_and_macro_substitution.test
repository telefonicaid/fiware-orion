# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify macro substitution in kafkaCustom headers and NGSI attributes when key resolves to null

--SHELL-INIT--
dbInit CB s1
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" orion
brokerStart CB 0 IPV4 -multiservice
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^orion.*"

--SHELL--

#
# 01. Create a custom Kafka subscription using macros in key, headers and NGSI attributes
# 02. Create entity E with context values and attribute overrides to trigger the subscription
# 03. Dump accumulator and verify that the key resolves to null, while headers and NGSI attributes
#     follow the expected macro substitution behavior
#

echo "01. Create a custom Kafka subscription using macros in key, headers and NGSI attributes"
echo "======================================================================================="
payload='{
  "subject": {
    "entities": [
      {
        "id" : "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "key": "${B}",
      "headers": {
        "myHeaderOne": "${B}",
        "myHeaderTwo": "${B}:${service}"
      },
      "ngsi": {
        "C": {
          "value": "${B}",
          "type": "Text"
        },
        "D": {
          "value": "${B}:${service}",
          "type": "Text"
        }
      }
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload" --tenant s1
echo
echo


echo "02. Create entity E with context values and attribute overrides to trigger the subscription"
echo "==========================================================================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Number"
  },
  "service": {
    "value": "OVERRIDE",
    "type": "Text"
  }
}'
orionCurl --url /v2/entities --payload "$payload" --tenant s1 --servicePath "/subservA" --xauthToken fgm
echo
echo


# Wait briefly to ensure the Kafka notification is stored by the accumulator
# before requesting the dump.
sleep 1s


echo "03. Dump accumulator and verify that the key resolves to null"
echo "============================================================="
accumulatorDump
echo
echo


--REGEXPECT--
01. Create a custom Kafka subscription using macros in key, headers and NGSI attributes
=======================================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create entity E with context values and attribute overrides to trigger the subscription
===========================================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T
Content-Length: 0



03. Dump accumulator and verify that the key resolves to null
=============================================================
Kafka message at topic orion
Key: (null)
Headers:
  Fiware-Service: s1
  Fiware-Servicepath: /subservA
  myheadertwo: null:OVERRIDE
Payload:
{
    "subscriptionId": "REGEX([0-9a-f\-]{24})",
    "data": [
        {
            "id": "E",
            "type": "T",
            "C": {
                "type": "Text",
                "value": null,
                "metadata": {}
            },
            "D": {
                "type": "Text",
                "value": "null:OVERRIDE",
                "metadata": {}
            },
            "A": {
                "type": "Number",
                "value": 1,
                "metadata": {}
            },
            "service": {
                "type": "Text",
                "value": "OVERRIDE",
                "metadata": {}
            }
        }
    ]
}
=======================================


--TEARDOWN--
brokerStop CB
dbDrop CB s1
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" orion