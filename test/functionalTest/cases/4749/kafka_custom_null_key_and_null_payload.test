# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify null key and null payload in kafkaCustom subscriptions

--SHELL-INIT--
dbInit CB
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" orion
brokerStart CB 0 IPV4
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^orion.*"

--SHELL--

#
# 01. Create a custom Kafka subscription with null key and null payload
# 02. Create entity E to trigger the subscription
# 03. Get subscriptions and verify that key and payload are stored as null
# 04. Dump accumulator and verify that the emitted Kafka message has a null key and empty payload
#

echo "01. Create a custom Kafka subscription with null key and null payload"
echo "====================================================================="
payload='{
  "subject": {
    "entities": [
      {
        "id" : "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "key": null,
      "payload": null
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "02. Create entity E to trigger the subscription"
echo "==============================================="
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": 1,
    "type": "Number"
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


# Wait briefly to ensure the Kafka notification is stored by the accumulator
# before requesting the dump.
sleep 1s


echo "03. Get subscriptions and verify that key and payload are stored as null"
echo "========================================================================="
orionCurl --url /v2/subscriptions
echo
echo


echo "04. Dump accumulator and verify that the emitted Kafka message has a null key and no payload"
echo "============================================================================================="
accumulatorDump
echo
echo

--REGEXPECT--
01. Create a custom Kafka subscription with null key and null payload
=====================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create entity E to trigger the subscription
===============================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T
Content-Length: 0



03. Get subscriptions and verify that key and payload are stored as null
=========================================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 456

[
    {
        "id": "REGEX([0-9a-f]{24})",
        "notification": {
            "attrs": [],
            "attrsFormat": "normalized",
            "covered": false,
            "kafkaCustom": {
                "key": null,
                "payload": null,
                "topic": "orion",
                "url": "kafka://localhost:9092,localhost:9094"
            },
            "lastNotification": "REGEX(.*)",
            "lastSuccess": "REGEX(.*)",
            "onlyChangedAttrs": false,
            "timesSent": 1
        },
        "status": "active",
        "subject": {
            "condition": {
                "attrs": [],
                "notifyOnMetadataChange": true
            },
            "entities": [
                {
                    "id": "E",
                    "type": "T"
                }
            ]
        }
    }
]


04. Dump accumulator and verify that the emitted Kafka message has a null key and no payload
=============================================================================================
Kafka message at topic orion
Key: (null)
Headers:
  Fiware-Servicepath: /
Payload:

=======================================


--TEARDOWN--
brokerStop CB
dbDrop CB
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" orion