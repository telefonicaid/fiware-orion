# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
Verify value resolution for kafkaCustom key and payload macros

--SHELL-INIT--
dbInit CB
kafkaCreateTopics "${KAFKA_BOOTSTRAP_A}" orion
brokerStart CB 0 IPV4
accumulatorStart --pretty-print --bootstrapServers "${KAFKA_BOOTSTRAP_A}" --kafkaTopic "^orion.*"

--SHELL--

#
# 01. Create a custom Kafka subscription using simple macros in key and payload
# 02. Create entity E with attribute A so both macros resolve to a concrete value
# 03. Get subscriptions and verify that the key and payload expressions are stored
# 04. Dump accumulator and verify that the emitted Kafka message contains the resolved key and payload
#

echo "01. Create a custom Kafka subscription using simple macros in key and payload"
echo "=============================================================================="
payload='{
  "subject": {
    "entities": [
      {
        "id" : "E",
        "type": "T"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9092,localhost:9094",
      "topic": "orion",
      "key": "${A}",
      "payload": "${A}"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


echo "02. Create entity E with attribute A so both macros resolve to a concrete value"
echo "================================================================================"
payload='{
  "id": "E",
  "type": "T",
  "A": {
    "value": "valueA",
    "type": "Text"
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


# Wait briefly to ensure the Kafka notification is stored by the accumulator
# before requesting the dump.
sleep 3s


echo "03. Get subscriptions and verify that the key and payload expressions are stored"
echo "================================================================================="
orionCurl --url /v2/subscriptions
echo
echo


echo "04. Dump accumulator and verify that the emitted Kafka message contains the resolved key and payload"
echo "===================================================================================================="
accumulatorDump
echo
echo


--REGEXPECT--
01. Create a custom Kafka subscription using simple macros in key and payload
==============================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f]{24})
Content-Length: 0



02. Create entity E with attribute A so both macros resolve to a concrete value
================================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E?type=T
Content-Length: 0




03. Get subscriptions and verify that the key and payload expressions are stored
=================================================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: REGEX([0-9]+)

[
    {
        "id": "REGEX([0-9a-f]{24})",
        "notification": {
            "attrs": [],
            "attrsFormat": "normalized",
            "covered": false,
            "kafkaCustom": {
                "key": "${A}",
                "payload": "${A}",
                "topic": "orion",
                "url": "kafka://localhost:9092,localhost:9094"
            },
            "lastNotification": "REGEX(.*)",
            "lastSuccess": "REGEX(.*)",
            "onlyChangedAttrs": false,
            "timesSent": 1
        },
        "status": "active",
        "subject": {
            "condition": {
                "attrs": [],
                "notifyOnMetadataChange": true
            },
            "entities": [
                {
                    "id": "E",
                    "type": "T"
                }
            ]
        }
    }
]


04. Dump accumulator and verify that the emitted Kafka message contains the resolved key and payload
====================================================================================================
Kafka message at topic orion
Key: valueA
Headers:
  Fiware-Servicepath: /
Payload:
valueA
=======================================


--TEARDOWN--
brokerStop CB
dbDrop CB
accumulatorStop
kafkaDestroyTopics "${KAFKA_BOOTSTRAP_A}" orion