        "covered": false,
        "kafkaCustom": {
            "topic": "orion",
            "url": "kafka://localhost:9092"
        },
        "onlyChangedAttrs": false
    },
    "status": "active",
    "subject": {
        "condition": {
            "attrs": [],
            "notifyOnMetadataChange": true
        },
        "entities": [
