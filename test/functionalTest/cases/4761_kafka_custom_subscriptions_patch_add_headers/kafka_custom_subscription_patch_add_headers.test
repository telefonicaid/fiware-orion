# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
kafkaCustom subscription update cases with headers

--SHELL-INIT--
dbInit CB
brokerStart CB

--SHELL--

#
# 01. Create kafkaCustom sub without headers
# 02. Get sub, see only url and topic in notification
# 03. Update sub element different to notification
# 04. Get sub, see only change the description
# 05. Update the sub and add fiware-service in notification headers
# 06. Get sub, see url, topic and fiware-service header in notification
# 07. Update the sub, add a custom header, and remove fiware-service
# 08. Get sub, see custom header, and verify removed fiware-service header
# 09. Update sub, change url to kafka://localhost:9095, keep headers unchanged
# 10. Get sub, see url changed to kafka://localhost:9095, topic and headers
# 11. Update sub to change headers
# 12. Get sub, verify that url, topic and headers were updated
#

echo "01. Create kafkaCustom sub without headers"
echo "=========================================="
payload='{
  "description": "Original sub",
  "subject": {
    "entities": [
      {
        "id": "E1",
        "type": "T1"
      }
    ]
  },
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9092",
      "topic": "orion"
    }
  }
}'
orionCurl --url /v2/subscriptions --payload "$payload"
echo
echo


SUB_ID=$(echo "$_responseHeaders" | grep Location | awk -F/ '{ print $4 }' | tr -d "\r\n")


echo "02. Get sub, see only url and topic in notification"
echo "==================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "03. Update sub element different to notification"
echo "================================================"
payload='{
  "description": "Modified sub"
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "04. Get sub, see only change the description"
echo "============================================"
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "05. Update the sub and add fiware-service in notification headers"
echo "================================================================="
payload='{
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9093",
      "topic": "cb",
      "headers":  {"fiware-service": "cucu"}
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "06. Get sub, see url, topic and fiware-service header in notification"
echo "====================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "07. Update the sub, add a custom header, and remove fiware-service"
echo "=================================================================="
payload='{
  "notification": {
    "kafkaCustom": {
      "url": "kafka://localhost:9094",
      "topic": "orion",
      "headers":  {"X-Device-Model": "Model-1"}
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "08. Get sub, see custom header, and verify removed fiware-service header"
echo "========================================================================"
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "09. Update sub, change url to kafka://localhost:9095, keep headers unchanged"
echo "============================================================================"
payload='{
  "notification": {
    "kafkaCustom": {
        "url": "kafka://localhost:9095",
        "topic": "orion"
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "10. Get sub, see url changed to kafka://localhost:9095, topic and headers"
echo "========================================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


echo "11. Update sub to change headers"
echo "================================"
payload='{
  "notification": {
    "kafkaCustom": {
        "url": "kafka://localhost:9095",
        "topic": "orion",
        "headers":  {"fiware-service": "cucu", "X-Device-Model": "Model-1"}
    }
  }
}'
orionCurl -X PATCH --url "/v2/subscriptions/$SUB_ID" --payload "$payload"
echo
echo


echo "12. Get sub, see url, topic and headers were updated"
echo "===================================================="
orionCurl --url /v2/subscriptions/$SUB_ID
echo
echo


--REGEXPECT--
01. Create kafkaCustom sub without headers
==========================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/subscriptions/REGEX([0-9a-f\-]{24})
Content-Length: 0



02. Get sub, see only url and topic in notification
===================================================
HTTP/1.1 200 OK
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Content-Type: application/json
Content-Length: 343

{
    "description": "Original sub",
    "id": "REGEX([0-9a-f\-]{24})",
    "notification": {
        "attrs": [],
        "attrsFormat": "normalized",
        "covered": false,
        "kafkaCustom": {
            "topic": "orion",
            "url": "kafka://localhost:9092"
        },
        "onlyChangedAttrs": false
    },
    "status": "active",
    "subject": {
        "condition": {
            "attrs": [],
            "notifyOnMetadataChange": true
        },
        "entities": [
            {
                "id": "E1",
                "type": "T1"
            }
        ]
    }
}


03. Update sub element different to notification
================================================
HTTP/1.1 204 No Content
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})



