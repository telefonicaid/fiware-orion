# VALGRIND_READY - to mark the test ready for valgrindTestSuite.sh

--NAME--
TextUnrestricted type and metadata combined support

--SHELL-INIT--
dbInit CB
brokerStart CB

--SHELL--

#
# 01. Create entity with attribute type TextUnrestricted and TextUnrestricted metadata true
# 02. Create entity with attribute type TextUnrestricted and TextUnrestricted metadata false
#

echo '01. Create entity with attribute type TextUnrestricted and TextUnrestricted metadata true'
echo '========================================================================================='
payload='{
  "id": "E5",
  "type": "T",
  "A": {
    "type": "TextUnrestricted",
    "value": "Value with <forbidden> characters (like = or ;)",
    "metadata": {
      "TextUnrestricted": {
        "value": true,
        "type": "Boolean"
      }
    }
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


echo '02. Create entity with attribute type TextUnrestricted and TextUnrestricted metadata false'
echo '=========================================================================================='
payload='{
  "id": "E6",
  "type": "T",
  "A": {
    "type": "TextUnrestricted",
    "value": "Value with <forbidden> characters (like = or ;)",
    "metadata": {
      "TextUnrestricted": {
        "value": false,
        "type": "Boolean"
      }
    }
  }
}'
orionCurl --url /v2/entities --payload "$payload"
echo
echo


--REGEXPECT--
01. Create entity with attribute type TextUnrestricted and TextUnrestricted metadata true
=========================================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E5?type=T
Content-Length: 0



02. Create entity with attribute type TextUnrestricted and TextUnrestricted metadata false
==========================================================================================
HTTP/1.1 201 Created
Date: REGEX(.*)
Fiware-Correlator: REGEX([0-9a-f\-]{36})
Location: /v2/entities/E6?type=T
Content-Length: 0



--TEARDOWN--
brokerStop CB
dbDrop CB
